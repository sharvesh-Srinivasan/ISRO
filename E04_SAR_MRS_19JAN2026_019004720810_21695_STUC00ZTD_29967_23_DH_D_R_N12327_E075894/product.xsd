<?xml version="1.0" encoding="UTF-8"?>
<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema" elementFormDefault="qualified">
  <xs:element name="Product">
    <xs:complexType>
      <xs:sequence>
        <xs:element ref="ProductType"/>
        <xs:element ref="ProductCopyright"/>
        <xs:element ref="DocumentIdentifier"/>
        <xs:element ref="DataCollectionTime"/>
        <xs:element ref="SourceAttributes"/>
        <xs:element ref="ImageGenerationParameters"/>
        <xs:element ref="ImageAttributes"/>
        <xs:element ref="CEOS-ARDProductAttributes"/>
      </xs:sequence>
    </xs:complexType>
  </xs:element>
  <xs:element name="ProductType" type="xs:string"/>
  <xs:element name="ProductCopyright" type="xs:string"/>
  <xs:element name="DocumentIdentifier">
    <xs:complexType>
      <xs:simpleContent>
        <xs:extension base="xs:anyURI">
          <xs:attribute name="name" use="required"/>
          <xs:attribute name="type" use="required" type="xs:NCName"/>
          <xs:attribute name="version" use="required" type="xs:decimal"/>
        </xs:extension>
      </xs:simpleContent>
    </xs:complexType>
  </xs:element>
  <xs:element name="DataCollectionTime">
    <xs:complexType>
      <xs:sequence>
        <xs:element ref="NumberOfAcquisitions"/>
        <xs:element ref="FirstAcquisitionDate"/>
        <xs:element ref="LastAcquisitionDate"/>
      </xs:sequence>
    </xs:complexType>
  </xs:element>
  <xs:element name="NumberOfAcquisitions" type="xs:integer"/>
  <xs:element name="FirstAcquisitionDate" type="xs:NMTOKEN"/>
  <xs:element name="LastAcquisitionDate" type="xs:NMTOKEN"/>
  <xs:element name="SourceAttributes">
    <xs:complexType>
      <xs:sequence>
        <xs:element ref="SourceDataRepository"/>
        <xs:element ref="Satellite"/>
        <xs:element ref="Instrument"/>
        <xs:element ref="ProductID"/>
        <xs:element ref="ImageId"/>
        <xs:element ref="InputDatasetFacilityId"/>
        <xs:element ref="BeamModeId"/>
        <xs:element ref="BeamModeMnemonic"/>
        <xs:element ref="SourceDataAcquisitionTime"/>
        <xs:element ref="SourceDataAcquisitionParameters"/>
        <xs:element ref="RawDataAttributes"/>
        <xs:element ref="OrbitAndAttitude"/>
      </xs:sequence>
      <xs:attribute name="acqID" use="required" type="xs:integer"/>
    </xs:complexType>
  </xs:element>
  <xs:element name="SourceDataRepository">
    <xs:complexType>
      <xs:simpleContent>
        <xs:extension base="xs:anyURI">
          <xs:attribute name="type" use="required" type="xs:NCName"/>
        </xs:extension>
      </xs:simpleContent>
    </xs:complexType>
  </xs:element>
  <xs:element name="Satellite" type="xs:NCName"/>
  <xs:element name="Instrument" type="xs:NCName"/>
  <xs:element name="ProductID" type="xs:integer"/>
  <xs:element name="ImageId" type="xs:NMTOKEN"/>
  <xs:element name="InputDatasetFacilityId" type="xs:NCName"/>
  <xs:element name="BeamModeId" type="xs:integer"/>
  <xs:element name="BeamModeMnemonic" type="xs:NCName"/>
  <xs:element name="SourceDataAcquisitionTime">
    <xs:complexType>
      <xs:sequence>
        <xs:element ref="StartTime"/>
        <xs:element ref="EndTime"/>
      </xs:sequence>
    </xs:complexType>
  </xs:element>
  <xs:element name="StartTime" type="xs:NMTOKEN"/>
  <xs:element name="EndTime" type="xs:NMTOKEN"/>
  <xs:element name="SourceDataAcquisitionParameters">
    <xs:complexType>
      <xs:sequence>
        <xs:element ref="ObservationMode"/>
        <xs:element ref="BeamID"/>
        <xs:element ref="Polarizations"/>
        <xs:element maxOccurs="unbounded" ref="PulsesReceivedPerDwell"/>
        <xs:element ref="RadarBand"/>
        <xs:element ref="RadarCenterFrequency"/>
        <xs:element maxOccurs="unbounded" ref="PulseRepetitionFrequency"/>
        <xs:element ref="PulseLength"/>
        <xs:element ref="PulseBandwidth"/>
        <xs:element ref="AntennaPointing"/>
        <xs:element ref="AdcSamplingRate"/>
        <xs:element ref="YawSteeringFlag"/>
        <xs:element ref="GeodeticFlag"/>
        <xs:element ref="RawBitsPerSample"/>
        <xs:element maxOccurs="unbounded" ref="SamplesPerEchoLine"/>
      </xs:sequence>
    </xs:complexType>
  </xs:element>
  <xs:element name="ObservationMode" type="xs:NCName"/>
  <xs:element name="BeamID" type="xs:string"/>
  <xs:element name="Polarizations" type="xs:string"/>
  <xs:element name="PulsesReceivedPerDwell">
    <xs:complexType>
      <xs:simpleContent>
        <xs:extension base="xs:integer">
          <xs:attribute name="beam" use="required" type="xs:decimal"/>
        </xs:extension>
      </xs:simpleContent>
    </xs:complexType>
  </xs:element>
  <xs:element name="RadarBand" type="xs:NCName"/>
  <xs:element name="RadarCenterFrequency">
    <xs:complexType>
      <xs:simpleContent>
        <xs:extension base="xs:double">
          <xs:attribute name="units" use="required" type="xs:NCName"/>
        </xs:extension>
      </xs:simpleContent>
    </xs:complexType>
  </xs:element>
  <xs:element name="PulseRepetitionFrequency">
    <xs:complexType>
      <xs:simpleContent>
        <xs:extension base="xs:decimal">
          <xs:attribute name="beam" use="required" type="xs:decimal"/>
          <xs:attribute name="units" use="required" type="xs:NCName"/>
        </xs:extension>
      </xs:simpleContent>
    </xs:complexType>
  </xs:element>
  <xs:element name="PulseLength">
    <xs:complexType>
      <xs:simpleContent>
        <xs:extension base="xs:double">
          <xs:attribute name="units" use="required" type="xs:NCName"/>
        </xs:extension>
      </xs:simpleContent>
    </xs:complexType>
  </xs:element>
  <xs:element name="PulseBandwidth">
    <xs:complexType>
      <xs:simpleContent>
        <xs:extension base="xs:integer">
          <xs:attribute name="units" use="required" type="xs:NCName"/>
        </xs:extension>
      </xs:simpleContent>
    </xs:complexType>
  </xs:element>
  <xs:element name="AntennaPointing" type="xs:NCName"/>
  <xs:element name="AdcSamplingRate">
    <xs:complexType>
      <xs:simpleContent>
        <xs:extension base="xs:decimal">
          <xs:attribute name="units" use="required" type="xs:NCName"/>
        </xs:extension>
      </xs:simpleContent>
    </xs:complexType>
  </xs:element>
  <xs:element name="YawSteeringFlag" type="xs:NCName"/>
  <xs:element name="GeodeticFlag" type="xs:NCName"/>
  <xs:element name="RawBitsPerSample" type="xs:integer"/>
  <xs:element name="SamplesPerEchoLine">
    <xs:complexType>
      <xs:simpleContent>
        <xs:extension base="xs:integer">
          <xs:attribute name="beam" use="required" type="xs:decimal"/>
        </xs:extension>
      </xs:simpleContent>
    </xs:complexType>
  </xs:element>
  <xs:element name="RawDataAttributes">
    <xs:complexType>
      <xs:sequence>
        <xs:element maxOccurs="unbounded" ref="RawDataAnalysis"/>
      </xs:sequence>
    </xs:complexType>
  </xs:element>
  <xs:element name="RawDataAnalysis">
    <xs:complexType>
      <xs:sequence>
        <xs:element maxOccurs="unbounded" ref="Bias"/>
        <xs:element maxOccurs="unbounded" ref="StandardDeviation"/>
        <xs:element ref="GainImbalance"/>
        <xs:element ref="PhaseOrthogonality"/>
        <xs:element maxOccurs="unbounded" ref="RawDataHistogram"/>
      </xs:sequence>
      <xs:attribute name="pol" use="required" type="xs:NCName"/>
    </xs:complexType>
  </xs:element>
  <xs:element name="Bias">
    <xs:complexType>
      <xs:simpleContent>
        <xs:extension base="xs:decimal">
          <xs:attribute name="dataStream" use="required" type="xs:NCName"/>
        </xs:extension>
      </xs:simpleContent>
    </xs:complexType>
  </xs:element>
  <xs:element name="GainImbalance" type="xs:decimal"/>
  <xs:element name="PhaseOrthogonality">
    <xs:complexType>
      <xs:simpleContent>
        <xs:extension base="xs:decimal">
          <xs:attribute name="units" use="required" type="xs:NCName"/>
        </xs:extension>
      </xs:simpleContent>
    </xs:complexType>
  </xs:element>
  <xs:element name="RawDataHistogram">
    <xs:complexType mixed="true">
      <xs:attribute name="dataStream" use="required" type="xs:NCName"/>
    </xs:complexType>
  </xs:element>
  <xs:element name="OrbitAndAttitude">
    <xs:complexType>
      <xs:sequence>
        <xs:element ref="OrbitInformation"/>
        <xs:element ref="AttitudeInformation"/>
      </xs:sequence>
    </xs:complexType>
  </xs:element>
  <xs:element name="OrbitInformation">
    <xs:complexType>
      <xs:sequence>
        <xs:element ref="PassDirection"/>
        <xs:element ref="OrbitDataSource"/>
        <xs:element ref="OrbitNumber"/>
        <xs:element maxOccurs="unbounded" ref="StateVector"/>
        <xs:element maxOccurs="unbounded" ref="StateVectorECEF"/>
      </xs:sequence>
    </xs:complexType>
  </xs:element>
  <xs:element name="PassDirection" type="xs:NCName"/>
  <xs:element name="OrbitDataSource" type="xs:NCName"/>
  <xs:element name="OrbitNumber" type="xs:integer"/>
  <xs:element name="StateVector">
    <xs:complexType>
      <xs:sequence>
        <xs:element ref="TimeStamp"/>
        <xs:element ref="xPosition"/>
        <xs:element ref="yPosition"/>
        <xs:element ref="zPosition"/>
        <xs:element ref="xVelocity"/>
        <xs:element ref="yVelocity"/>
        <xs:element ref="zVelocity"/>
        <xs:element ref="siderealangle"/>
      </xs:sequence>
    </xs:complexType>
  </xs:element>
  <xs:element name="siderealangle">
    <xs:complexType>
      <xs:simpleContent>
        <xs:extension base="xs:decimal">
          <xs:attribute name="units" use="required" type="xs:NCName"/>
        </xs:extension>
      </xs:simpleContent>
    </xs:complexType>
  </xs:element>
  <xs:element name="StateVectorECEF">
    <xs:complexType>
      <xs:sequence>
        <xs:element ref="TimeStamp"/>
        <xs:element ref="xPosition"/>
        <xs:element ref="yPosition"/>
        <xs:element ref="zPosition"/>
        <xs:element ref="xVelocity"/>
        <xs:element ref="yVelocity"/>
        <xs:element ref="zVelocity"/>
      </xs:sequence>
    </xs:complexType>
  </xs:element>
  <xs:element name="AttitudeInformation">
    <xs:complexType>
      <xs:sequence>
        <xs:element ref="AttitudeDataSource"/>
        <xs:element ref="AttitudeOffsetsApplied"/>
        <xs:element maxOccurs="unbounded" ref="AttitudeAngles"/>
      </xs:sequence>
    </xs:complexType>
  </xs:element>
  <xs:element name="AttitudeDataSource" type="xs:string"/>
  <xs:element name="AttitudeOffsetsApplied" type="xs:boolean"/>
  <xs:element name="AttitudeAngles">
    <xs:complexType>
      <xs:sequence>
        <xs:element ref="TimeStamp"/>
        <xs:element ref="yaw"/>
        <xs:element ref="roll"/>
        <xs:element ref="pitch"/>
      </xs:sequence>
    </xs:complexType>
  </xs:element>
  <xs:element name="yaw">
    <xs:complexType>
      <xs:simpleContent>
        <xs:extension base="xs:decimal">
          <xs:attribute name="units" use="required" type="xs:NCName"/>
        </xs:extension>
      </xs:simpleContent>
    </xs:complexType>
  </xs:element>
  <xs:element name="roll">
    <xs:complexType>
      <xs:simpleContent>
        <xs:extension base="xs:decimal">
          <xs:attribute name="units" use="required" type="xs:NCName"/>
        </xs:extension>
      </xs:simpleContent>
    </xs:complexType>
  </xs:element>
  <xs:element name="pitch">
    <xs:complexType>
      <xs:simpleContent>
        <xs:extension base="xs:decimal">
          <xs:attribute name="units" use="required" type="xs:NCName"/>
        </xs:extension>
      </xs:simpleContent>
    </xs:complexType>
  </xs:element>
  <xs:element name="ImageGenerationParameters">
    <xs:complexType>
      <xs:sequence>
        <xs:element ref="SourceProcParam"/>
        <xs:element ref="SarProcessingInformation"/>
        <xs:element ref="DopplerCentroid"/>
        <xs:element ref="DopplerRateValues"/>
        <xs:element maxOccurs="unbounded" ref="Chirp"/>
        <xs:element maxOccurs="unbounded" ref="PerformanceIndicators"/>
        <xs:element ref="SlantRangeToGroundRange"/>
      </xs:sequence>
    </xs:complexType>
  </xs:element>
  <xs:element name="SourceProcParam">
    <xs:complexType>
      <xs:sequence>
        <xs:element ref="ProductLevel"/>
        <xs:element ref="ProcessingFacility"/>
        <xs:element ref="ProcessingDate"/>
        <xs:element ref="SoftwareVersion"/>
      </xs:sequence>
    </xs:complexType>
  </xs:element>
  <xs:element name="ProductLevel" type="xs:NCName"/>
  <xs:element name="ProcessingDate" type="xs:NMTOKEN"/>
  <xs:element name="SarProcessingInformation">
    <xs:complexType>
      <xs:sequence>
        <xs:element ref="lutApplied"/>
        <xs:element ref="ElevationPatternCorrection"/>
        <xs:element ref="RawDataCorrection"/>
        <xs:element ref="RangeReferenceFunctionSource"/>
        <xs:element ref="DopplerSource"/>
        <xs:element ref="DopplerAmbiguityComputed"/>
        <xs:element ref="DopplerAmbiguityUsed"/>
        <xs:element ref="EstimatedRollAngleUsed"/>
        <xs:element ref="RadiometricSmoothingPerformed"/>
        <xs:element ref="ZeroDopplerTimeFirstLine"/>
        <xs:element ref="ZeroDopplerTimeLastLine"/>
        <xs:choice maxOccurs="unbounded">
          <xs:element ref="NumberOfLinesProcessed"/>
          <xs:element ref="NumberOfMissingLines"/>
        </xs:choice>
        <xs:element maxOccurs="unbounded" ref="SamplingWindowStartTimeFirstRawLine"/>
        <xs:element maxOccurs="unbounded" ref="SamplingWindowStartTimeLastRawLine"/>
        <xs:element maxOccurs="unbounded" ref="NumberOfSwstChanges"/>
        <xs:element ref="RangeNumberOfLooks"/>
        <xs:element ref="RangeLookBandwidth"/>
        <xs:element ref="TotalProcessedRangeBandwidth"/>
        <xs:element ref="AzimuthNumberOfLooks"/>
        <xs:element ref="AzimuthLookBandwidth"/>
        <xs:element ref="TotalProcessedAzimuthBandwidth"/>
        <xs:element ref="AzimuthWindow"/>
        <xs:element ref="RangeWindow"/>
        <xs:element ref="SourceDataGeometry"/>
        <xs:element ref="SourceGeographicalExtent"/>
        <xs:element ref="AzimuthPixelSpacing"/>
        <xs:element ref="RangePixelSpacing"/>
        <xs:element ref="AzimuthResolution"/>
        <xs:element ref="RangeResolution"/>
        <xs:element ref="IncAngleNearRange"/>
        <xs:element ref="IncAngleFarRange"/>
        <xs:element ref="SlantRangeNearEdge"/>
        <xs:element ref="SatelliteHeight"/>
      </xs:sequence>
    </xs:complexType>
  </xs:element>
  <xs:element name="lutApplied" type="xs:NCName"/>
  <xs:element name="ElevationPatternCorrection" type="xs:boolean"/>
  <xs:element name="RawDataCorrection" type="xs:boolean"/>
  <xs:element name="RangeReferenceFunctionSource" type="xs:string"/>
  <xs:element name="DopplerSource" type="xs:NCName"/>
  <xs:element name="DopplerAmbiguityComputed" type="xs:boolean"/>
  <xs:element name="DopplerAmbiguityUsed" type="xs:boolean"/>
  <xs:element name="EstimatedRollAngleUsed" type="xs:boolean"/>
  <xs:element name="RadiometricSmoothingPerformed" type="xs:boolean"/>
  <xs:element name="ZeroDopplerTimeFirstLine" type="xs:NMTOKEN"/>
  <xs:element name="ZeroDopplerTimeLastLine" type="xs:NMTOKEN"/>
  <xs:element name="NumberOfLinesProcessed">
    <xs:complexType>
      <xs:simpleContent>
        <xs:extension base="xs:integer">
          <xs:attribute name="pol" use="required" type="xs:NCName"/>
        </xs:extension>
      </xs:simpleContent>
    </xs:complexType>
  </xs:element>
  <xs:element name="NumberOfMissingLines">
    <xs:complexType>
      <xs:simpleContent>
        <xs:extension base="xs:integer">
          <xs:attribute name="pol" use="required" type="xs:NCName"/>
        </xs:extension>
      </xs:simpleContent>
    </xs:complexType>
  </xs:element>
  <xs:element name="SamplingWindowStartTimeFirstRawLine">
    <xs:complexType>
      <xs:simpleContent>
        <xs:extension base="xs:decimal">
          <xs:attribute name="beam" use="required" type="xs:decimal"/>
          <xs:attribute name="units" use="required" type="xs:NCName"/>
        </xs:extension>
      </xs:simpleContent>
    </xs:complexType>
  </xs:element>
  <xs:element name="SamplingWindowStartTimeLastRawLine">
    <xs:complexType>
      <xs:simpleContent>
        <xs:extension base="xs:decimal">
          <xs:attribute name="beam" use="required" type="xs:decimal"/>
          <xs:attribute name="units" use="required" type="xs:NCName"/>
        </xs:extension>
      </xs:simpleContent>
    </xs:complexType>
  </xs:element>
  <xs:element name="NumberOfSwstChanges">
    <xs:complexType>
      <xs:simpleContent>
        <xs:extension base="xs:integer">
          <xs:attribute name="beam" use="required" type="xs:decimal"/>
        </xs:extension>
      </xs:simpleContent>
    </xs:complexType>
  </xs:element>
  <xs:element name="RangeNumberOfLooks" type="xs:integer"/>
  <xs:element name="RangeLookBandwidth">
    <xs:complexType>
      <xs:simpleContent>
        <xs:extension base="xs:decimal">
          <xs:attribute name="units" use="required" type="xs:NCName"/>
        </xs:extension>
      </xs:simpleContent>
    </xs:complexType>
  </xs:element>
  <xs:element name="TotalProcessedRangeBandwidth">
    <xs:complexType>
      <xs:simpleContent>
        <xs:extension base="xs:decimal">
          <xs:attribute name="units" use="required" type="xs:NCName"/>
        </xs:extension>
      </xs:simpleContent>
    </xs:complexType>
  </xs:element>
  <xs:element name="AzimuthNumberOfLooks" type="xs:integer"/>
  <xs:element name="AzimuthLookBandwidth">
    <xs:complexType>
      <xs:simpleContent>
        <xs:extension base="xs:decimal">
          <xs:attribute name="units" use="required" type="xs:NCName"/>
        </xs:extension>
      </xs:simpleContent>
    </xs:complexType>
  </xs:element>
  <xs:element name="TotalProcessedAzimuthBandwidth">
    <xs:complexType>
      <xs:simpleContent>
        <xs:extension base="xs:decimal">
          <xs:attribute name="units" use="required" type="xs:NCName"/>
        </xs:extension>
      </xs:simpleContent>
    </xs:complexType>
  </xs:element>
  <xs:element name="AzimuthWindow">
    <xs:complexType>
      <xs:sequence>
        <xs:element ref="WindowName"/>
        <xs:element ref="WindowCoefficient"/>
      </xs:sequence>
    </xs:complexType>
  </xs:element>
  <xs:element name="RangeWindow">
    <xs:complexType>
      <xs:sequence>
        <xs:element ref="WindowName"/>
        <xs:element ref="WindowCoefficient"/>
      </xs:sequence>
    </xs:complexType>
  </xs:element>
  <xs:element name="SourceDataGeometry" type="xs:string"/>
  <xs:element name="SourceGeographicalExtent">
    <xs:complexType mixed="true">
      <xs:attribute name="type" use="required" type="xs:NCName"/>
    </xs:complexType>
  </xs:element>
  <xs:element name="AzimuthPixelSpacing">
    <xs:complexType>
      <xs:simpleContent>
        <xs:extension base="xs:decimal">
          <xs:attribute name="units" use="required" type="xs:NCName"/>
        </xs:extension>
      </xs:simpleContent>
    </xs:complexType>
  </xs:element>
  <xs:element name="RangePixelSpacing">
    <xs:complexType>
      <xs:simpleContent>
        <xs:extension base="xs:decimal">
          <xs:attribute name="units" use="required" type="xs:NCName"/>
        </xs:extension>
      </xs:simpleContent>
    </xs:complexType>
  </xs:element>
  <xs:element name="AzimuthResolution">
    <xs:complexType>
      <xs:simpleContent>
        <xs:extension base="xs:decimal">
          <xs:attribute name="units" use="required" type="xs:NCName"/>
        </xs:extension>
      </xs:simpleContent>
    </xs:complexType>
  </xs:element>
  <xs:element name="RangeResolution">
    <xs:complexType>
      <xs:simpleContent>
        <xs:extension base="xs:decimal">
          <xs:attribute name="units" use="required" type="xs:NCName"/>
        </xs:extension>
      </xs:simpleContent>
    </xs:complexType>
  </xs:element>
  <xs:element name="IncAngleNearRange">
    <xs:complexType>
      <xs:simpleContent>
        <xs:extension base="xs:decimal">
          <xs:attribute name="units" use="required" type="xs:NCName"/>
        </xs:extension>
      </xs:simpleContent>
    </xs:complexType>
  </xs:element>
  <xs:element name="IncAngleFarRange">
    <xs:complexType>
      <xs:simpleContent>
        <xs:extension base="xs:decimal">
          <xs:attribute name="units" use="required" type="xs:NCName"/>
        </xs:extension>
      </xs:simpleContent>
    </xs:complexType>
  </xs:element>
  <xs:element name="SlantRangeNearEdge">
    <xs:complexType>
      <xs:simpleContent>
        <xs:extension base="xs:decimal">
          <xs:attribute name="units" use="required" type="xs:NCName"/>
        </xs:extension>
      </xs:simpleContent>
    </xs:complexType>
  </xs:element>
  <xs:element name="SatelliteHeight">
    <xs:complexType>
      <xs:simpleContent>
        <xs:extension base="xs:decimal">
          <xs:attribute name="units" use="required" type="xs:NCName"/>
        </xs:extension>
      </xs:simpleContent>
    </xs:complexType>
  </xs:element>
  <xs:element name="DopplerCentroid">
    <xs:complexType>
      <xs:sequence>
        <xs:element ref="TimeOfDopplerCentroidEstimate"/>
        <xs:element ref="DopplerAmbiguity"/>
        <xs:element ref="DopplerCentroidPolynomialPeriod"/>
        <xs:element ref="DopplerCentroidCoefficients"/>
      </xs:sequence>
    </xs:complexType>
  </xs:element>
  <xs:element name="TimeOfDopplerCentroidEstimate" type="xs:NMTOKEN"/>
  <xs:element name="DopplerAmbiguity" type="xs:integer"/>
  <xs:element name="DopplerCentroidPolynomialPeriod">
    <xs:complexType>
      <xs:simpleContent>
        <xs:extension base="xs:integer">
          <xs:attribute name="units" use="required" type="xs:NCName"/>
        </xs:extension>
      </xs:simpleContent>
    </xs:complexType>
  </xs:element>
  <xs:element name="DopplerCentroidCoefficients" type="xs:string"/>
  <xs:element name="DopplerRateValues">
    <xs:complexType>
      <xs:sequence>
        <xs:element ref="DopplerRateReferenceTime"/>
        <xs:element ref="DopplerRateValuesCoefficients"/>
      </xs:sequence>
    </xs:complexType>
  </xs:element>
  <xs:element name="DopplerRateReferenceTime" type="xs:NMTOKEN"/>
  <xs:element name="DopplerRateValuesCoefficients">
    <xs:complexType mixed="true">
      <xs:attribute name="units" use="required" type="xs:NCName"/>
    </xs:complexType>
  </xs:element>
  <xs:element name="Chirp">
    <xs:complexType>
      <xs:sequence>
        <xs:element ref="ChirpQuality"/>
      </xs:sequence>
      <xs:attribute name="pol" use="required" type="xs:NCName"/>
    </xs:complexType>
  </xs:element>
  <xs:element name="ChirpQuality">
    <xs:complexType>
      <xs:sequence>
        <xs:element ref="CrossCorrelationWidth"/>
        <xs:element ref="SideLobeLevel"/>
        <xs:element ref="IntegratedSideLobeRatio"/>
        <xs:element ref="CrossCorrelationPeakLoc"/>
      </xs:sequence>
    </xs:complexType>
  </xs:element>
  <xs:element name="CrossCorrelationWidth" type="xs:decimal"/>
  <xs:element name="SideLobeLevel">
    <xs:complexType>
      <xs:simpleContent>
        <xs:extension base="xs:decimal">
          <xs:attribute name="units" use="required" type="xs:NCName"/>
        </xs:extension>
      </xs:simpleContent>
    </xs:complexType>
  </xs:element>
  <xs:element name="IntegratedSideLobeRatio">
    <xs:complexType>
